# ============================================================================
# Ankora — Environment variables (EXAMPLE)
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill the values for your environment.
# NEVER commit `.env.local` or any file containing real secrets.
# ============================================================================

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development"

# ---------- Supabase ----------
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — NEVER expose this to the browser.
# Has admin access — bypasses RLS. Use only in trusted server contexts.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------- Upstash Redis (rate limiting) ----------
# Provision via Vercel Marketplace > Upstash
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ---------- Security ----------
# Used to sign audit log entries and other internal tokens.
# Generate with: openssl rand -base64 32
INTERNAL_SECRET="change-me-to-a-random-32-byte-string"

# ---------- Observability (optional in dev) ----------
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
