# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing / coverage
/coverage
/playwright-report
/test-results
/blob-report
/.lighthouseci

# next.js
/.next/
/out/
next-env.d.ts

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# supabase
/supabase/.branches
/supabase/.temp
/supabase/.env

# editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json

# typescript
*.tsbuildinfo

# OS
.cache/
tmp/

.vercel

# Claude Code runtime (les agents/commands sont versionnés, pas les lock/tmp)
.claude/scheduled_tasks.lock
.claude/tmp/
.claude/logs/
# Repertoire de worktrees temporaires interne (non utilise — la convention
# canonique Ankora pour les git worktrees est `F:/PROJECTS/Apps/ankora-worktrees/`,
# externe au repo). Gitignored par precaution si un outil tiers le recree.
.claude/worktrees/

# Tool-specific derivatives auto-générés depuis .claude/ (canonical source)
# Ces dossiers sont créés par OpenAI Codex CLI et autres outils tiers.
# Ne JAMAIS modifier directement — toujours éditer .claude/ et laisser le tool régénérer.
.codex/
.agents/

# outputs temporaires (scripts locaux)
/outputs/

# local design mockups
design-mockup-*.html

# Design snapshots & handoff packages (research preview Claude Design — locaux uniquement)
# Le ZIP brut est lourd et reproductible ; on garde design-snapshots/README.md tracké pour la convention.
design-snapshots/*.zip
design_handoff_ankora_v1/

# Claude Code local settings
.claude/settings.local.json

# internal PR prompts — drafts ignored, canonical PR-*.md briefs tracked via exception
# Pattern explanation: `prompts/*` (vs `prompts/`) lets Git evaluate the exception
# on individual files. The `!prompts/PR-*.md` line re-includes canonical PR briefs
# referenced by CLAUDE.md, ROADMAP.md, and ADRs (specs that MUST be versioned).
prompts/*
!prompts/PR-*.md

# Playwright MCP temp folder
.playwright-mcp/

# Screenshots and visual test artifacts
/screenshots/
/*.png
/*.jpg

# CC handoffs (Obsidian sync, ne pas committer en repo)
cc-handoffs/
.tmp/
